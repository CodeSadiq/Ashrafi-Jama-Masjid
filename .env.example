# MongoDB connection URI (with password URL-encoded)
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster-url>/<db-name>?retryWrites=true&w=majority

# Default Admin Credentials
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=your_secure_password_here

# Backend configuration
PORT=5000

# Admin Access Code (Frontend)
VITE_ADMIN_CODE=your_admin_access_code_here
